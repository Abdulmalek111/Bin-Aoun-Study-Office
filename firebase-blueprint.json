{
  "entities": {
    "support_ticket": {
      "title": "support_ticket",
      "description": "Tech support interaction with chat history and open/closed status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderEmail": { "type": "string" },
        "senderName": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string" },
        "reply": { "type": "string" },
        "repliedAt": { "type": "string" },
        "messages": {
          "type": "array"
        }
      },
      "required": ["id", "senderEmail", "senderName", "message", "createdAt"]
    },
    "forum_message": {
      "title": "forum_message",
      "description": "A message posted to a discussion board of a specific subject",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subjectId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorRole": { "type": "string" },
        "avatarSeed": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string" },
        "likes": { "type": "number" }
      },
      "required": ["id", "subjectId", "authorName", "authorRole", "content", "timestamp", "likes"]
    },
    "notification": {
      "title": "notification",
      "description": "A system notification dispatched to a target student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderName": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" },
        "read": { "type": "boolean" },
        "targetEmail": { "type": "string" }
      },
      "required": ["id", "senderName", "message", "createdAt", "read", "targetEmail"]
    }
  },
  "firestore": {
    "support_tickets/{ticketId}": {
      "schema": "support_ticket",
      "description": "Customer support and chat ticket for active students"
    },
    "discussions/{msgId}": {
      "schema": "forum_message",
      "description": "Shared online educational group discussion boards"
    },
    "notifications/{notiId}": {
      "schema": "notification",
      "description": "Real-time alerts, announcements, and replies to support inquiries"
    }
  }
}
