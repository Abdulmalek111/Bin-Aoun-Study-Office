{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile database document linked to the user's uid.",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "User's display name or username."
        },
        "email": {
          "type": "string",
          "description": "User's verified email address."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the user's initials/avatar illustration."
        },
        "telegram": {
          "type": "string",
          "description": "Telegram nickname/username for study alerts."
        },
        "isLoggedIn": {
          "type": "boolean",
          "description": "Whether the user logged in."
        },
        "balance": {
          "type": "number",
          "description": "The financial wallet credit balance of the student."
        },
        "academicStage": {
          "type": "string",
          "description": "Academic stage (بكالوريوس, ماستر, دكتوراة)"
        },
        "academicYear": {
          "type": "string",
          "description": "Academic year of the student."
        },
        "academicSemester": {
          "type": "string",
          "description": "Academic semester."
        },
        "academicTrack": {
          "type": "string",
          "description": "Academic track."
        }
      },
      "required": ["username", "email"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "A student support ticket requesting review or assistance.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the ticket."
        },
        "senderEmail": {
          "type": "string",
          "description": "Email address of the student who created the ticket."
        },
        "senderName": {
          "type": "string",
          "description": "Name of the student who created the ticket."
        },
        "message": {
          "type": "string",
          "description": "Initial help request message."
        },
        "createdAt": {
          "type": "string",
          "description": "Formatted timestamp when the ticket was created."
        },
        "status": {
          "type": "string",
          "enum": ["open", "closed"],
          "description": "Current status of the technical support issue."
        },
        "reply": {
          "type": "string",
          "description": "Support feedback or reply text."
        },
        "repliedAt": {
          "type": "string",
          "description": "Formatted timestamp of support response."
        }
      },
      "required": ["id", "senderEmail", "senderName", "message", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single discussion post message inside a ticket or group chat.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Message id."
        },
        "senderRole": {
          "type": "string",
          "enum": ["student", "admin"],
          "description": "Role of the chat sender."
        },
        "senderName": {
          "type": "string",
          "description": "Display name of the message sender."
        },
        "message": {
          "type": "string",
          "description": "Internal body text of the chat post."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the chat was posted."
        }
      },
      "required": ["id", "senderRole", "senderName", "message", "createdAt"]
    },
    "ForumMessage": {
      "title": "ForumMessage",
      "description": "A collaborative community discussion board message in a specific study channel.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique Forum Message ID."
        },
        "subjectId": {
          "type": "string",
          "description": "Associated subject channel ID (e.g. math, physics)."
        },
        "authorName": {
          "type": "string",
          "description": "Display name of the poster."
        },
        "authorRole": {
          "type": "string",
          "enum": ["student", "instructor", "moderator"],
          "description": "System role of the poster in discussions."
        },
        "avatarSeed": {
          "type": "string",
          "description": "Username seed for initials avatar display."
        },
        "content": {
          "type": "string",
          "description": "Body markdown/text content of the post."
        },
        "timestamp": {
          "type": "string",
          "description": "Human-friendly readable timestamp description."
        },
        "likes": {
          "type": "integer",
          "description": "Current total likes count on this question/post."
        }
      },
      "required": ["id", "subjectId", "authorName", "authorRole", "content", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Personal student notification alerting them of responses or critical announcements.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique notification ID."
        },
        "senderName": {
          "type": "string",
          "description": "Sender name of the notice (usually مشرف المنصة)."
        },
        "message": {
          "type": "string",
          "description": "Notification message text."
        },
        "createdAt": {
          "type": "string",
          "description": "Formatted timestamp details."
        },
        "read": {
          "type": "boolean",
          "description": "Read receipts status."
        },
        "targetEmail": {
          "type": "string",
          "description": "The destination email address of the notification target."
        }
      },
      "required": ["id", "senderName", "message", "createdAt", "read", "targetEmail"]
    },
    "ExamHistoryItem": {
      "title": "ExamHistoryItem",
      "description": "The result record of an exam completed by a student.",
      "type": "object",
      "properties": {
        "examTitle": {
          "type": "string",
          "description": "Name/Title of the taken exam."
        },
        "scorePct": {
          "type": "integer",
          "description": "Score percentages obtained (0 to 100)."
        },
        "date": {
          "type": "string",
          "description": "Date completed."
        },
        "timeUsed": {
          "type": "string",
          "description": "Formatted test timer duration."
        }
      },
      "required": ["examTitle", "scorePct", "date", "timeUsed"]
    },
    "SubjectLectures": {
      "title": "SubjectLectures",
      "description": "Ordered lists of educational video and document elements for subjects.",
      "type": "object",
      "properties": {
        "lectures": {
          "type": "array",
          "description": "Lectures elements representing educational material."
        }
      },
      "required": ["lectures"]
    },
    "PrivateChat": {
      "title": "PrivateChat",
      "description": "Private direct chat channel between two students.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "integer" }
      },
      "required": ["id", "participants"]
    },
    "PrivateMessage": {
      "title": "PrivateMessage",
      "description": "A single private text message sent between students.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderUid": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "integer" }
      },
      "required": ["id", "senderUid", "senderName", "content", "timestamp"]
    },
    "PrivateCall": {
      "title": "PrivateCall",
      "description": "A 1-on-1 private voice call between two students.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "callerUid": { "type": "string" },
        "callerName": { "type": "string" },
        "calleeUid": { "type": "string" },
        "calleeName": { "type": "string" },
        "status": { "type": "string", "enum": ["calling", "ringing", "accepted", "declined", "ended"] },
        "createdAt": { "type": "integer" },
        "offer": { "type": "object" },
        "answer": { "type": "object" },
        "callerCandidates": { "type": "array" },
        "calleeCandidates": { "type": "array" }
      },
      "required": ["id", "callerUid", "callerName", "calleeUid", "calleeName", "status", "createdAt"]
    },
    "VoiceRoom": {
      "title": "VoiceRoom",
      "description": "Real-time Discord-like voice chat rooms for classes.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["public", "private"] },
        "ownerId": { "type": "string" },
        "maxUsers": { "type": "integer" },
        "isLocked": { "type": "boolean" },
        "allowedRoles": { "type": "array" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "name", "type", "ownerId", "maxUsers", "isLocked", "allowedRoles", "createdAt", "updatedAt"]
    },
    "VoiceMember": {
      "title": "VoiceMember",
      "description": "Active participant connected to a voice room.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "moderator", "teacher", "student"] },
        "isMuted": { "type": "boolean" },
        "isDeafened": { "type": "boolean" },
        "isSpeaking": { "type": "boolean" },
        "handRaised": { "type": "boolean" },
        "joinedAt": { "type": "string" },
        "lastSeen": { "type": "string" },
        "socketId": { "type": "string" },
        "isOnline": { "type": "boolean" }
      },
      "required": ["uid", "displayName", "photoURL", "role", "isMuted", "isDeafened", "isSpeaking", "handRaised", "joinedAt", "lastSeen", "socketId", "isOnline"]
    },
    "VoiceCall": {
      "title": "VoiceCall",
      "description": "A WebRTC peer-to-peer audio call connection between room members.",
      "type": "object",
      "properties": {
        "callerId": { "type": "string" },
        "calleeId": { "type": "string" },
        "status": { "type": "string", "enum": ["calling", "accepted", "ended"] },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" },
        "offer": { "type": "object" },
        "answer": { "type": "object" }
      },
      "required": ["callerId", "calleeId", "status", "createdAt", "updatedAt"]
    },
    "IceCandidate": {
      "title": "IceCandidate",
      "description": "A single WebRTC ICE candidate packet exchanged during handshake.",
      "type": "object",
      "properties": {
        "candidate": { "type": "string" },
        "sdpMid": { "type": "string" },
        "sdpMLineIndex": { "type": "integer" }
      },
      "required": ["candidate", "sdpMid", "sdpMLineIndex"]
    },
    "VoiceBan": {
      "title": "VoiceBan",
      "description": "Banned user from a specific voice room.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "bannedBy": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "bannedBy", "reason", "createdAt"]
    },
    "VoiceEvent": {
      "title": "VoiceEvent",
      "description": "Historical events logged for audit trail within a voice room.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "uid": { "type": "string" },
        "targetUid": { "type": "string" },
        "createdAt": { "type": "string" },
        "metadata": { "type": "object" }
      },
      "required": ["type", "uid", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles database."
    },
    "private_chats/{chatId}": {
      "schema": "PrivateChat",
      "description": "Private direct chat collections between students."
    },
    "private_chats/{chatId}/messages/{messageId}": {
      "schema": "PrivateMessage",
      "description": "Subcollection containing private messages sent inside a private chat."
    },
    "private_calls/{callId}": {
      "schema": "PrivateCall",
      "description": "Private 1-on-1 voice calling sessions between students."
    },
    "subject_lectures/{subjectId}": {
      "schema": "SubjectLectures",
      "description": "Educational study sheets, files and resources for subjects."
    },
    "tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Educational student technical support tickets."
    },
    "tickets/{ticketId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Subcollection thread inside a student ticket."
    },
    "discussions/{messageId}": {
      "schema": "ForumMessage",
      "description": "Real-time forum discussions board posts."
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Personal alerts and admin notifications."
    },
    "users/{userId}/exams/{examId}": {
      "schema": "ExamHistoryItem",
      "description": "Completed student exam history logs."
    },
    "voice_rooms/{roomId}": {
      "schema": "VoiceRoom",
      "description": "Discord-like voice rooms metadata document."
    },
    "voice_rooms/{roomId}/members/{memberId}": {
      "schema": "VoiceMember",
      "description": "Connected active voice members inside the room."
    },
    "voice_rooms/{roomId}/bans/{banId}": {
      "schema": "VoiceBan",
      "description": "Banned users record within the voice room."
    },
    "voice_rooms/{roomId}/events/{eventId}": {
      "schema": "VoiceEvent",
      "description": "Audit trails and moderation log events."
    },
    "voice_rooms/{roomId}/calls/{callId}": {
      "schema": "VoiceCall",
      "description": "WebRTC peer connection calls between room members."
    },
    "voice_rooms/{roomId}/calls/{callId}/callerCandidates/{candidateId}": {
      "schema": "IceCandidate",
      "description": "ICE candidate packets from caller."
    },
    "voice_rooms/{roomId}/calls/{callId}/calleeCandidates/{candidateId}": {
      "schema": "IceCandidate",
      "description": "ICE candidate packets from callee."
    }
  }
}
